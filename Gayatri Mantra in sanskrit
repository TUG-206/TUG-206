# AUDIO SIMULATION
# ==============================================================================
class AudioSimulator:
    """Simulate mantra chanting"""
    
    @staticmethod
    def play_mantra(duration: int = 30):
        """Simulate playing mantra chant"""
        Terminal.print_color("\n🎵  Playing Gayatri Mantra Chant  🎵", Fore.YELLOW, Style.BRIGHT)
        Terminal.rule("─", Fore.CYAN)
        
        syllables = ["ॐ", "भूः", "भुवः", "स्वः", "तत्", "सवितुः", "वरेण्यं", 
                     "भर्गः", "देवस्य", "धीमहि", "धियः", "यः", "नः", "प्रचोदयात्"]
        
        start_time = time.time()
        while time.time() - start_time < duration:
            for syllable in syllables:
                elapsed = time.time() - start_time
                if elapsed >= duration:
                    break
                
                # Random colors for visual effect
                colors = [Fore.YELLOW, Fore.LIGHTYELLOW_EX, Fore.CYAN, Fore.LIGHTCYAN_EX]
                color = random.choice(colors)
                
                print(f"\r{color}{syllable}{Style.RESET_ALL}  ", end='', flush=True)
                
                # Animated progress bar
                progress = min(1.0, elapsed / duration)
                bars = int(progress * 30)
                print(f"[{'█'*bars}{'░'*(30-bars)}] ", end='', flush=True)
                
                time.sleep(0.5)
        
        print("\n\n✓ Chant completed!")
        Terminal.rule("─", Fore.CYAN)

