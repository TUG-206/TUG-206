# EXPORT FUNCTIONALITY
# ==============================================================================
def export_to_file(filename: str = "gayatri_mantra.txt") -> bool:
    """Export mantra to text file"""
    try:
        with open(filename, 'w', encoding='utf-8') as f:
            f.write("="*60 + "\n")
            f.write("गायत्री मन्त्र".center(60) + "\n")
            f.write("Gayatri Mantra".center(60) + "\n")
            f.write("="*60 + "\n\n")
            
            f.write("SANSKRIT:\n")
            for verse in GayatriMantra.SANSKRIT:
                f.write(verse + "\n")
            
            f.write("\nTRANSLITERATION:\n")
            for verse in GayatriMantra.TRANSLITERATION:
                f.write(verse + "\n")
            
            f.write("\nWORD MEANINGS:\n")
            for word, meaning in GayatriMantra.WORD_MEANINGS:
                f.write(f"{word} - {meaning}\n")
            
            f.write("\nCOMPLETE MEANING:\n")
            f.write(GayatriMantra.COMPLETE_MEANING + "\n")
            
            f.write("\n" + "="*60 + "\n")
        
        Terminal.print_color(f"\n✓ Mantra exported to {filename}", Fore.GREEN, Style.BRIGHT)
        return True
    except Exception as e:
        Terminal.print_color(f"\n✗ Error exporting: {e}", Fore.RED)
        return False

