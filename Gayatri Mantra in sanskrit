    def show_sections_menu(self):
        """Display sections menu"""
        Terminal.clear()
        Terminal.header("📑  SELECT A SECTION", "")
        
        sections = [
            ("1", "📿 Main Mantra"),
            ("2", "📖 Word Meanings"),
            ("3", "📜 Complete Meaning"),
            ("4", "📊 Mantra Details"),
            ("5", "✨ Benefits"),
            ("6", "⏰ Best Time to Chant"),
            ("7", "📿 Method of Chanting"),
            ("8", "💫 Sacred Quote"),
            ("9", "◀ Back to Main Menu")
        ]
        
        for key, desc in sections:
            print(f"  {Fore.LIGHTCYAN_EX}{key}{Style.RESET_ALL}. {desc}")
        
        print()
        return input(f"  {Fore.LIGHTYELLOW_EX}Enter your choice (1-9): {Style.RESET_ALL}").strip()
    
    def run_section(self, choice: str):
        """Run selected section"""
        Terminal.clear()
        
        if choice == '1':
            self.display.show_title()
            self.display.show_mantra()
        elif choice == '2':
            self.display.show_title()
            self.display.show_word_meanings()
        elif choice == '3':
            self.display.show_title()
            self.display.show_meaning()
        elif choice == '4':
            self.display.show_title()
            self.display.show_info_grid()
        elif choice == '5':
            self.display.show_title()
            self.display.show_benefits()
        elif choice == '6':
            self.display.show_title()
            self.display.show_times()
        elif choice == '7':
            self.display.show_title()
            self.display.show_method()
        elif choice == '8':
            self.display.show_title()
            self.display.show_quote()
        else:
            return False
        
        Terminal.footer()
        input(f"\n  {Fore.LIGHTYELLOW_EX}Press Enter to continue...{Style.RESET_ALL}")
        return True
    
    def run(self):
        """Main menu loop"""
        # Check Unicode support
        if not supports_unicode():
            Terminal.print_color("\n⚠ Warning: Your terminal may not display Devanagari correctly.", Fore.YELLOW)
            Terminal.print_color("For best experience, use a Unicode-compatible terminal.\n", Fore.YELLOW)
            time.sleep(2)
        
        while True:
            choice = self.show_main_menu()
            
            if choice == '1':
                Terminal.clear()
                self.display.show_all()
                input(f"\n  {Fore.LIGHTYELLOW_EX}Press Enter to continue...{Style.RESET_ALL}")
            
            elif choice == '2':
                while True:
                    section_choice = self.show_sections_menu()
                    if section_choice == '9':
                        break
                    if not self.run_section(section_choice):
                        break
            
            elif choice == '3':
                Terminal.clear()
                self.display.show_title()
                self.audio.play_mantra(20)  # 20 seconds simulation
                input(f"\n  {Fore.LIGHTYELLOW_EX}Press Enter to continue...{Style.RESET_ALL}")
            
            elif choice == '4':
                Terminal.clear()
                self.display.show_title()
                filename = input("Enter filename (default: gayatri_mantra.txt): ").strip()
                if not filename:
                    filename = "gayatri_mantra.txt"
                export_to_file(filename)
                input(f"\n  {Fore.LIGHTYELLOW_EX}Press Enter to continue...{Style.RESET_ALL}")
            
            elif choice == '5':
                Terminal.clear()
                Terminal.header("ℹ️  ABOUT", "")
                print(f"""
  {Fore.LIGHTCYAN_EX}Gayatri Mantra Terminal Application{Style.RESET_ALL}
  
  Version      : 1.0.0
  Author       : Traditional (Composed by Sage Vishwamitra)
  Language     : Sanskrit (संस्कृत)
  Platform     : Python 3.6+
  Features     : • Full Devanagari display
                 • Interactive menu system
                 • Word-by-word meanings
                 • Audio simulation
                 • Export functionality
                 • Color-coded output
  
  {Fore.LIGHTGREEN_EX}The Gayatri Mantra is considered the essence of all four Vedas
  and the most sacred mantra in Sanatan Dharma.{Style.RESET_ALL}
                """)
                Terminal.footer()
                input(f"\n  {Fore.LIGHTYELLOW_EX}Press Enter to continue...{Style.RESET_ALL}")
            
            elif choice == '6':
                Terminal.clear()
                Animations.pulse("🕉️  ॐ शान्तिः शान्तिः शान्तिः  🕉️", 3)
                Terminal.print_color("\nThank you for experiencing the Gayatri Mantra!", Fore.GREEN)
                Terminal.print_color("May the Divine Light Illuminate Your Path ✨\n", Fore.LIGHTYELLOW_EX)
