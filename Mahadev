    "attribution": "✧ रावणेन विरचितं शिवस्तोत्रम् ✧",
    "description": "The Shiv Tandav Stotram is a hymn of praise to Lord Shiva composed by Ravana, the king of Lanka.",
    "total_verses": 15
}

def clear_screen():
    """Clear the terminal screen"""
    os.system('cls' if os.name == 'nt' else 'clear')

def print_colored(text, color=Fore.YELLOW, brightness=Style.NORMAL, end='\n'):
    """Print colored text if colorama is available"""
    if COLORS_AVAILABLE:
        print(f"{brightness}{color}{text}{Style.RESET_ALL}", end=end)
    else:
        print(text, end=end)

def print_header():
    """Print the stotram header"""
    width = 80
    print_colored("=" * width, Fore.CYAN, Style.BRIGHT)
    print_colored(STOTRAM_INFO["title"].center(width), Fore.YELLOW, Style.BRIGHT)
    print_colored(STOTRAM_INFO["subtitle"].center(width), Fore.GREEN)
    print_colored("=" * width, Fore.CYAN, Style.BRIGHT)
    print()

def print_footer():
    """Print the stotram footer"""
    width = 80
    print()
    print_colored("=" * width, Fore.CYAN, Style.BRIGHT)
    print_colored(STOTRAM_INFO["footer"].center(width), Fore.YELLOW, Style.BRIGHT)
    print_colored(STOTRAM_INFO["attribution"].center(width), Fore.GREEN)
    print_colored("=" * width, Fore.CYAN, Style.BRIGHT)

def print_verse(verse_num, verse_text):
    """Print a single verse with formatting"""
    print_colored(f"॥{verse_num}॥", Fore.CYAN, Style.BRIGHT, end=' ')
    print_colored(verse_text, Fore.YELLOW)
    print()

def display_all_verses():
    """Display all verses continuously"""
    print_header()
    for verse in SHIV_TANDAV_VERSES:
        print_verse(verse["number"], verse["sanskrit"])
        time.sleep(0.5)  # Small delay between verses for readability
    print_footer()

def display_verse_by_verse():
    """Display verses one by one with user interaction"""
    print_header()
    print_colored("Press ENTER for next verse, 'q' to quit, 'p' for previous", Fore.GREEN)
    print_colored("-" * 60, Fore.CYAN)
    
    current_verse = 0
    while 0 <= current_verse < len(SHIV_TANDAV_VERSES):
        verse = SHIV_TANDAV_VERSES[current_verse]
        print_colored(f"\nVerse {current_verse + 1}/{len(SHIV_TANDAV_VERSES)}", Fore.CYAN, Style.BRIGHT)
        print_verse(verse["number"], verse["sanskrit"])
        
        user_input = input("\n[Enter/n/p/q]: ").strip().lower()
        
        if user_input == 'q':
            break
        elif user_input == 'p':
            current_verse = max(0, current_verse - 1)
        else:
            current_verse += 1
    
    print_footer()

def display_random_verse():
    """Display a random verse"""
    import random
    verse = random.choice(SHIV_TANDAV_VERSES)
    print_header()
    print_colored(f"Random Verse {verse['number']}/{len(SHIV_TANDAV_VERSES)}", Fore.CYAN, Style.BRIGHT)
    print_verse(verse["number"], verse["sanskrit"])
    print_footer()

def search_verses(search_term):
    """Search for a term in verses"""
    print_header()
    print_colored(f"Search results for: '{search_term}'", Fore.CYAN, Style.BRIGHT)
    print_colored("-" * 60, Fore.CYAN)
    
    found = False
    for i, verse in enumerate(SHIV_TANDAV_VERSES, 1):
        if search_term.lower() in verse["sanskrit"].lower():
            print_colored(f"\nVerse {i}:", Fore.GREEN, Style.BRIGHT)
            print_verse(verse["number"], verse["sanskrit"])
            found = True
    
    if not found:
        print_colored("No verses found containing the search term.", Fore.RED)
    
    print_footer()

def export_to_file(filename="shiv_tandav_stotram.txt"):
    """Export the stotram to a text file"""
    try:
        with open(filename, 'w', encoding='utf-8') as f:
            f.write("=" * 80 + "\n")
            f.write(STOTRAM_INFO["title"].center(80) + "\n")
            f.write(STOTRAM_INFO["subtitle"].center(80) + "\n")
            f.write("=" * 80 + "\n\n")
            
            for i, verse in enumerate(SHIV_TANDAV_VERSES, 1):
                f.write(f"॥{verse['number']}॥ ")
                f.write(verse["sanskrit"] + "\n\n")
            
            f.write("=" * 80 + "\n")
            f.write(STOTRAM_INFO["footer"].center(80) + "\n")
            f.write(STOTRAM_INFO["attribution"].center(80) + "\n")
            f.write("=" * 80 + "\n")
        
        print_colored(f"✓ Stotram exported to {filename}", Fore.GREEN, Style.BRIGHT)
        return True
    except Exception as e:
        print_colored(f"✗ Error exporting: {e}", Fore.RED)
        return False

def show_stats():
    """Display statistics about the stotram"""
    total_verses = len(SHIV_TANDAV_VERSES)
    total_chars = sum(len(v["sanskrit"]) for v in SHIV_TANDAV_VERSES)
    
    print_header()
    print_colored("STOTRAM STATISTICS", Fore.CYAN, Style.BRIGHT)
    print_colored("-" * 40, Fore.CYAN)
    print_colored(f"Total Verses: {total_verses}", Fore.YELLOW)
    print_colored(f"Total Characters: {total_chars:,}", Fore.YELLOW)
    print_colored(f"Average Verse Length: {total_chars // total_verses} chars", Fore.YELLOW)
    print_colored(f"Composer: Ravana (दशवक्त्र)", Fore.YELLOW)
    print_colored(f"Deity: Lord Shiva (शिव)", Fore.YELLOW)
    print_colored(f"Language: Sanskrit (संस्कृत)", Fore.YELLOW)
    print_footer()

def main_menu():
    """Display main menu and handle user choice"""
    while True:
        clear_screen()
        print_colored("=" * 60, Fore.CYAN, Style.BRIGHT)
        print_colored("शिवताण्डवस्तोत्रम्".center(60), Fore.YELLOW, Style.BRIGHT)
        print_colored("Shiv Tandav Stotram - Python Edition".center(60), Fore.GREEN)
        print_colored("=" * 60, Fore.CYAN, Style.BRIGHT)
        print()
        print_colored("1. Display all verses", Fore.WHITE)
        print_colored("2. Read verse by verse (interactive)", Fore.WHITE)
        print_colored("3. Show random verse", Fore.WHITE)
        print_colored("4. Search in verses", Fore.WHITE)
        print_colored("5. Export to text file", Fore.WHITE)
        print_colored("6. Show statistics", Fore.WHITE)
        print_colored("7. About", Fore.WHITE)
        print_colored("8. Exit", Fore.WHITE)
        print()
        
        choice = input("Enter your choice (1-8): ").strip()
        
        if choice == '1':
            clear_screen()
            display_all_verses()
            input("\nPress Enter to continue...")
        elif choice == '2':
            clear_screen()
            display_verse_by_verse()
            input("\nPress Enter to continue...")
        elif choice == '3':
            clear_screen()
            display_random_verse()
            input("\nPress Enter to continue...")
        elif choice == '4':
            clear_screen()
            search_term = input("Enter search term: ").strip()
            clear_screen()
            search_verses(search_term)
            input("\nPress Enter to continue...")
        elif choice == '5':
            clear_screen()
            filename = input("Enter filename (default: shiv_tandav_stotram.txt): ").strip()
            if not filename:
                filename = "shiv_tandav_stotram.txt"
            export_to_file(filename)
            input("\nPress Enter to continue...")
        elif choice == '6':
            clear_screen()
            show_stats()
            input("\nPress Enter to continue...")
        elif choice == '7':
            clear_screen()
            print_header()
            print_colored(STOTRAM_INFO["description"], Fore.WHITE)
            print_colored("\nThis hymn describes the cosmic dance (Tandava) of Lord Shiva", Fore.WHITE)
            print_colored("and is traditionally attributed to Ravana, the great devotee", Fore.WHITE)
            print_colored("of Shiva and king of Lanka.", Fore.WHITE)
            print_footer()
            input("\nPress Enter to continue...")
        elif choice == '8':
            print_colored("\nॐ नमः शिवाय", Fore.YELLOW, Style.BRIGHT)
            print_colored("Thank you for using Shiv Tandav Stotram. Har Har Mahadev! 🙏", Fore.GREEN)
            break
        else:
            print_colored("Invalid choice! Please try again.", Fore.RED)
            time.sleep(1)

def main():
    """Main function"""
    # Check if terminal supports Unicode
    if not supports_unicode():
        print("Warning: Your terminal may not display Devanagari script correctly.")
        print("For best experience, use a Unicode-compatible terminal.")
        time.sleep(2)
    
    # Clear screen and show welcome message
    clear_screen()
    print_colored("🕉️  ॐ नमः शिवाय  🕉️", Fore.YELLOW, Style.BRIGHT)
    print_colored("Loading Shiv Tandav Stotram...", Fore.CYAN)
    time.sleep(1)
    
    # Start main menu
    main_menu()

if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        print_colored("\n\n🙏 ॐ नमः शिवाय 🙏", Fore.YELLOW, Style.BRIGHT)
        print_colored("Program terminated by user. Har Har Mahadev!", Fore.GREEN)
        sys.exit(0)
    except Exception as e:
        print_colored(f"\nAn error occurred: {e}", Fore.RED)
        sys.exit(1)
