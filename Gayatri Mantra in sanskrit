# ==============================================================================
# TERMINAL UTILITIES
# ==============================================================================
class Terminal:
    """Terminal display utilities"""
    
    WIDTH = 80
    
    @staticmethod
    def clear():
        """Clear terminal screen"""
        os.system('cls' if os.name == 'nt' else 'clear')
    
    @staticmethod
    def print_color(text: str, color=Fore.YELLOW, style=Style.NORMAL, end='\n'):
        """Print colored text"""
        if COLORS_AVAILABLE:
            print(f"{style}{color}{text}{Style.RESET_ALL}", end=end)
        else:
            print(text, end=end)
    
    @staticmethod
    def center(text: str, width: int = None) -> str:
        """Center text"""
        if width is None:
            width = Terminal.WIDTH
        return text.center(width)
    
    @staticmethod
    def rule(char: str = "═", color=Fore.CYAN):
        """Print a horizontal rule"""
        Terminal.print_color(char * Terminal.WIDTH, color, Style.BRIGHT)
    
    @staticmethod
    def header(title: str, subtitle: str = ""):
        """Print formatted header"""
        Terminal.rule("═")
        Terminal.print_color(Terminal.center(title), Fore.YELLOW, Style.BRIGHT)
        if subtitle:
            Terminal.print_color(Terminal.center(subtitle), Fore.GREEN)
        Terminal.rule("═")
        print()
    
    @staticmethod
    def footer():
        """Print formatted footer"""
        print()
        Terminal.rule("═")
        Terminal.print_color(Terminal.center("॥ ॐ शान्तिः शान्तिः शान्तिः ॥"), Fore.YELLOW, Style.BRIGHT)
        Terminal.print_color(Terminal.center("गायत्री मन्त्र - सर्वमङ्गलमयी विद्या"), Fore.GREEN)
        Terminal.print_color(Terminal.center("May the Divine Light Illuminate Your Path ✨"), Fore.LIGHTYELLOW_EX)
        Terminal.rule("═")
    
    @staticmethod
    def progress_bar(seconds: float = 2.0, message: str = "Loading"):
        """Display an animated progress bar"""
        print(f"{message} ", end='', flush=True)
        for i in range(20):
            print("█", end='', flush=True)
            time.sleep(seconds / 20)
        print(" ✓")

# ==============================================================================
# ANIMATION UTILITIES
# ==============================================================================
class Animations:
    """Animation effects for terminal"""
    
    @staticmethod
    def typing(text: str, delay: float = 0.05, color=Fore.LIGHTWHITE_EX):
        """Typewriter effect"""
        for char in text:
            Terminal.print_color(char, color, end='', flush=True)
            time.sleep(delay)
        print()
    
    @staticmethod
    def pulse(text: str, duration: float = 2.0):
        """Pulsing text effect"""
        if not COLORS_AVAILABLE:
            print(text)
            return
        
        start_time = time.time()
        while time.time() - start_time < duration:
            for i in range(10, 0, -1):
                brightness = i / 10
                print(f"\r{Fore.YELLOW}{text}{Style.RESET_ALL}", end='')
                time.sleep(0.05)
            for i in range(1, 11):
                brightness = i / 10
                print(f"\r{Fore.YELLOW}{text}{Style.RESET_ALL}", end='')
                time.sleep(0.05)
        print()
    
    @staticmethod
    def shimmer(text: str, duration: float = 2.0):
        """Shimmering text effect"""
        if not COLORS_AVAILABLE:
            print(text)
            return
        
        colors = [Fore.YELLOW, Fore.LIGHTYELLOW_EX, Fore.WHITE, Fore.LIGHTYELLOW_EX]
        end_time = time.time() + duration
        while time.time() < end_time:
            for color in colors:
                print(f"\r{color}{text}{Style.RESET_ALL}", end='')
                time.sleep(0.1)
        print()

